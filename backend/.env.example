# Server
PORT=5001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://medease_user:medease_dev_password@localhost:5433/medease

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_TTL=604800

# CORS
CORS_ORIGIN=http://localhost:3000

# Cloudflare Turnstile (CAPTCHA) — test key (always passes)
CLOUDFLARE_SECRET_KEY=1x0000000000000000000000000000000AA

# AWS S3 (Profile Image Uploads)
# In production, use IAM roles instead of static credentials
S3_BUCKET=your-s3-bucket-name
S3_REGION=your-s3-region
S3_ACCESS_KEY_ID=your-iam-access-key-id
S3_SECRET_ACCESS_KEY=your-iam-secret-access-key

# Logging
LOG_LEVEL=debug

# SMTP (Email Verification)
# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-email@gmail.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM=MedEase <your-smtp-email@gmail.com>

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:3000

# OTP settings
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=3

# Appointment Reminders
# Set to 'false' to disable the reminder scheduler
REMINDER_ENABLED=true
# Comma-separated hours before appointment to send reminders (e.g. 24,1)
REMINDER_HOURS_BEFORE=24,1
# Cron schedule for the reminder check job (default: every 5 minutes)
REMINDER_CRON_SCHEDULE=*/5 * * * *
