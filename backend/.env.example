# Server
PORT=5001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://medease_user:medease_dev_password@localhost:5433/medease

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# Cloudflare Turnstile (CAPTCHA) — test key (always passes)
CLOUDFLARE_SECRET_KEY=1x0000000000000000000000000000000AA

# Logging
LOG_LEVEL=debug

# SMTP (Email Verification)
# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# SMTP_FROM: full display format — e.g. MedEase <noreply@yourdomain.com>
# If omitted, SMTP_USER is used as the sender address.
SMTP_FROM=MedEase <your-email@gmail.com>

# OTP settings
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=3
