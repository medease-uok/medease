# Server
PORT=5001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://medease_user:medease_dev_password@localhost:5433/medease

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_TTL=604800

# CORS
CORS_ORIGIN=http://localhost:3000

# Cloudflare Turnstile (CAPTCHA) — test key (always passes)
CLOUDFLARE_SECRET_KEY=1x0000000000000000000000000000000AA

# AWS S3 (Profile Image Uploads)
S3_BUCKET=your-s3-bucket-name
S3_REGION=eu-north-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Logging
LOG_LEVEL=debug
