{
  "name": "medease-backend",
  "version": "1.0.0",
  "description": "MedEase Hospital Management System - Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --verbose --forceExit",
    "db:seed": "docker exec -i medease-db psql -U medease_user -d medease < ../database/seed.sql",
    "db:reset": "docker compose -f ../docker-compose.yml down -v && docker compose -f ../docker-compose.yml up -d"
  },
  "keywords": [
    "hospital",
    "management",
    "api",
    "healthcare"
  ],
  "author": "MedEase Team",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.14"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/src/tests/**/*.test.js"
    ]
  }
}
